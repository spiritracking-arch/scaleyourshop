        <div style={{ display: "inline-block", padding: "5px 14px", borderRadius: 999, background: "#f0f0f0", fontSize: 12, fontWeight: 700, color: "#666", letterSpacing: "0.8px", marginBottom: 20 }}>
          FONCTIONNALITÉS
