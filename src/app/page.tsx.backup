              <div style={{ display: "inline-block", padding: "4px 12px", borderRadius: 999, background: "#f0f0f0", fontSize: 11, fontWeight: 700, color: "#888", letterSpacing: "0.8px", marginBottom: 16 }}>{f.tag}</div>
              <h3 style={{ fontSize: "1.75rem", fontWeight: 800, letterSpacing: "-0.8px", color: "#1a1a1a", margin: "0 0 16px", lineHeight: 1.2 }}>{f.title}</h3>
              <p style={{ fontSize: 16, color: "#777", lineHeight: 1.7, maxWidth: "48ch" }}>{f.desc}</p>
            </div>

            {/* Visual */}
            <div style={{ direction: "ltr", background: "white", borderRadius: 16, padding: 24, border: "1px solid #e5e5e5", boxShadow: "0 4px 20px rgba(0,0,0,0.06)" }}>
              {f.visual && !f.isVariant && (
                <div style={{ display: "grid", gap: 10 }}>
                  {f.visual.map((item: any, j: number) => (
                    <div key={j} style={{ display: "flex", alignItems: "center", gap: 12, padding: "10px 14px", borderRadius: 8, background: j === 0 ? "#f9f9f9" : "white", border: "1px solid #f0f0f0" }}>
                      <span style={{ fontSize: 18 }}>{item.lang}</span>
                      <span style={{ fontSize: 13, color: j === 0 ? "#1a1a1a" : "#888", fontWeight: j === 0 ? 600 : 400 }}>{item.text}</span>
                      {j === 0 && <span style={{ marginLeft: "auto", fontSize: 11, color: "#1a1a1a", fontWeight: 700, background: "#f0f0f0", padding: "2px 8px", borderRadius: 999 }}>SOURCE</span>}
                    </div>
                  ))}
                </div>
              )}
              {f.isVariant && f.visual && (
                <div>
                  <div style={{ fontSize: 12, fontWeight: 700, color: "#999", letterSpacing: "0.8px", marginBottom: 14 }}>SÉLECTEUR DE VARIANTE</div>
                  <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
                    {f.visual.map((v: any, j: number) => (
                      <div key={j} style={{ padding: "10px 12px", borderRadius: 8, border: j === 0 ? "2px solid #1a1a1a" : "1px solid #e5e5e5", background: j === 0 ? "#f9f9f9" : "white", display: "flex", alignItems: "center", gap: 8 }}>
                        <div style={{ width: 28, height: 28, borderRadius: 6, background: "#f0f0f0", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 14 }}>{v.img}</div>
                        <span style={{ fontSize: 11, fontWeight: 500, color: "#444", lineHeight: 1.3 }}>{v.label}</span>
                      </div>
                    ))}
                  </div>
                  <div style={{ marginTop: 14, padding: "8px 12px", borderRadius: 8, background: "#f9f9f9", fontFamily: "monospace", fontSize: 11, color: "#888" }}>
                    4 variantes · 4 images WebP · prix dédiés
                  </div>
                </div>
              )}
              {f.isFlow && (
                <div style={{ display: "flex", flexDirection: "column", gap: 10, alignItems: "center" }}>
                  <div style={{ padding: "12px 24px", borderRadius: 10, background: "#1a1a1a", color: "white", fontWeight: 700, fontSize: 14, width: "100%", textAlign: "center" }}>
                    boutique-source.com (source)
                  </div>
                  <div style={{ fontSize: 20, color: "#ccc" }}>↓</div>
                  <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8, width: "100%" }}>
                    {["shop-fr", "shop-de", "shop-es", "shop-it", "shop-nl", "shop-pt"].map(shop => (
                      <div key={shop} style={{ padding: "8px 12px", borderRadius: 8, background: "#f9f9f9", border: "1px solid #e5e5e5", fontSize: 12, fontWeight: 600, color: "#666", textAlign: "center" }}>
                        {shop}
                      </div>
                    ))}
                  </div>
                  <div style={{ fontSize: 12, color: "#bbb", marginTop: 4 }}>+ autant de boutiques cibles que nécessaire</div>
                </div>
              )}
            </div>
          </div>
        </FadeIn>
      ))}
    </section>
  );
}

function Pricing() {
  const [annual, setAnnual] = useState(false);

  function ctaLabel(plan: typeof PLANS[0]) {
    if (plan.type === "once") return `Commencer — ${plan.price.once}€`;
    const monthly = plan.price.monthly ?? 0;
    const displayed = annual ? Math.round(monthly * 0.8) : monthly;
    return `Démarrer — ${displayed}€/mois`;
  }

  function ctaHref(plan: typeof PLANS[0]) {
    const planId = plan.id.toUpperCase();
    if (plan.type === "once") return `/signup?plan=${planId}`;
    return `/signup?plan=${planId}&billing=${annual ? "annual" : "monthly"}`;
  }

  return (
    <section id="pricing" style={{ background: "#fafafa", padding: "clamp(5rem,10vw,9rem) 40px" }}>
      <div style={{ maxWidth: 1100, margin: "0 auto" }}>
        <FadeIn style={{ textAlign: "center", marginBottom: 32 }}>
          <div style={{ display: "inline-block", padding: "5px 14px", borderRadius: 999, background: "#f0f0f0", fontSize: 12, fontWeight: 700, color: "#666", letterSpacing: "0.8px", marginBottom: 20 }}>
            TARIFS
          </div>
          <h2 style={{ fontSize: "clamp(2rem,3.5vw,3rem)", fontWeight: 900, letterSpacing: "-1.5px", color: "#1a1a1a", margin: "0 0 16px" }}>
            Du one-shot au business
          </h2>
          <p style={{ fontSize: 17, color: "#888", marginBottom: 32, maxWidth: "48ch", margin: "0 auto 32px" }}>
            Commencez avec un paiement unique pour tester, scalez avec un abonnement.
          </p>
          <div style={{ display: "inline-flex", background: "#ebebeb", borderRadius: 999, padding: 4 }}>
            {[{ label: "Mensuel", val: false }, { label: "Annuel  −20%", val: true }].map(({ label, val }) => (
              <button key={label} onClick={() => setAnnual(val)} style={{
                padding: "8px 20px", borderRadius: 999, border: annual === val ? "1.5px solid #1a1a1a" : "1.5px solid transparent", fontWeight: 700, fontSize: 14, cursor: "pointer",
                background: annual === val ? "white" : "transparent",
                color: annual === val ? "#1a1a1a" : "#787878",
                boxShadow: annual === val ? "0 1px 4px rgba(0,0,0,0.1)" : "none",
                transition: "all 200ms",
              }}>{label}</button>
            ))}
          </div>
          {annual && (
            <div style={{ fontSize: 12, color: "#aaa", marginTop: 10 }}>
              Facturation annuelle (Growth) · Payé d'avance, non remboursable · Renouvellement automatique, annulable avant l'échéance.
            </div>
          )}
        </FadeIn>

        <FadeIn delay={40}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 10, marginBottom: 48, padding: "12px 20px", background: "#fff7ed", border: "1px solid #fed7aa", borderRadius: 12, flexWrap: "wrap" }}>
            <span style={{ fontSize: 13, color: "#9a3412", fontWeight: 600 }}>
              Pas encore prêt ? Testez gratuitement avec <strong>5 produits</strong> — sans carte bancaire.
            </span>
            <Link href="/signup" style={{ fontSize: 13, fontWeight: 700, color: "#1a1a1a", textDecoration: "underline" }}>
              Commencer gratuitement →
            </Link>
          </div>
        </FadeIn>

        <div className="pricing-grid" style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 24 }}>
          {PLANS.map((plan, i) => (
            <FadeIn key={plan.id} delay={i * 80}>
              <div style={{
                background: "white", borderRadius: 20, padding: 32, position: "relative",
                border: plan.popular ? "2px solid #1a1a1a" : "1px solid #e5e5e5",
                boxShadow: plan.popular ? "0 12px 40px rgba(0,0,0,0.1)" : "0 2px 8px rgba(0,0,0,0.04)",
                height: "100%", boxSizing: "border-box",
              }}>
                {plan.popular && (
                  <div style={{ position: "absolute", top: -14, left: "50%", transform: "translateX(-50%)", padding: "5px 18px", borderRadius: 999, background: "#1a1a1a", color: "white", fontSize: 12, fontWeight: 700, whiteSpace: "nowrap" }}>
                    Le plus populaire
                  </div>
                )}
                <div style={{ fontWeight: 800, fontSize: 22, color: "#1a1a1a", marginBottom: 6 }}>{plan.name}</div>
                <div style={{ fontSize: 13, color: "#999", marginBottom: 28, lineHeight: 1.5 }}>{plan.desc}</div>

                <div style={{ marginBottom: 28 }}>
                  {plan.type === "once" ? (
                    <>
                      <span style={{ fontSize: 44, fontWeight: 900, letterSpacing: "-2px", color: "#1a1a1a" }}>{plan.price.once}€</span>
                      <span style={{ fontSize: 14, color: "#aaa", marginLeft: 8 }}>paiement unique</span>
                    </>
                  ) : (
                    <>
                      <span style={{ fontSize: 44, fontWeight: 900, letterSpacing: "-2px", color: "#1a1a1a" }}>
                        {annual ? Math.round((plan.price.monthly ?? 0) * 0.8) : plan.price.monthly}€
                      </span>
                      <span style={{ fontSize: 14, color: "#aaa", marginLeft: 8 }}>/mois</span>
                      {annual && <div style={{ fontSize: 12, color: "#16a34a", fontWeight: 700, marginTop: 4 }}>Soit {Math.round((plan.price.monthly ?? 0) * 0.8 * 12)}€/an · −20%</div>}
                    </>
                  )}
                </div>

                <Link href={ctaHref(plan)} style={{
                  width: "100%", padding: "13px", borderRadius: 10,
                  border: plan.popular ? "none" : "1.5px solid #1a1a1a",
                  background: plan.popular ? "#1a1a1a" : "white",
                  color: plan.popular ? "white" : "#1a1a1a",
                  fontWeight: 700, fontSize: 14, cursor: "pointer", marginBottom: 10,
                  display: "block", textAlign: "center", textDecoration: "none", boxSizing: "border-box",
                }}>
                  {ctaLabel(plan)}
                </Link>
                <div style={{ fontSize: 12, color: "#bbb", textAlign: "center", marginBottom: 28 }}>{plan.note}</div>

                <div style={{ borderTop: "1px solid #f0f0f0", paddingTop: 20, display: "grid", gap: 11 }}>
                  {plan.features.map((f, j) => (
                    <div key={j} style={{ display: "flex", alignItems: "center", gap: 9, fontSize: 13, color: f.ok ? "#333" : "#707070" }}>
                      <span style={{ fontSize: 12, color: f.ok ? "#1a1a1a" : "#707070", flexShrink: 0, fontWeight: 700 }}>{f.ok ? "✓" : "✗"}</span>
                      {f.text}
                    </div>
                  ))}
                </div>
              </div>
            </FadeIn>
          ))}
        </div>

        <FadeIn delay={160}>
          <div id="contact" style={{ marginTop: 24, padding: "22px 28px", background: "white", borderRadius: 16, border: "1px solid #e5e5e5", display: "flex", alignItems: "center", justifyContent: "space-between", gap: 16, flexWrap: "wrap" }}>
            <div>
              <div style={{ fontWeight: 800, fontSize: 16, color: "#1a1a1a" }}>Enterprise / Sur mesure</div>
              <div style={{ fontSize: 14, color: "#999", marginTop: 4 }}>Volume au-delà de 5 000 produits/mois · Intégrations custom · SLA garanti · Facturation annuelle</div>
            </div>
            <a href="mailto:contact@scaleyourshop.app" style={{ padding: "11px 24px", borderRadius: 10, border: "1.5px solid #1a1a1a", background: "white", fontWeight: 700, fontSize: 14, cursor: "pointer", whiteSpace: "nowrap", textDecoration: "none", color: "#1a1a1a" }}>
              Nous contacter →
            </a>
          </div>
        </FadeIn>
      </div>
    </section>
  );
}

function FAQ() {
  const [open, setOpen] = useState<number | null>(null);
  return (
    <section id="faq" style={{ maxWidth: 720, margin: "0 auto", padding: "clamp(5rem,10vw,9rem) 40px clamp(2.5rem,5vw,4rem)" }}>
      <FadeIn style={{ textAlign: "center", marginBottom: 56 }}>
        <div style={{ display: "inline-block", padding: "5px 14px", borderRadius: 999, background: "#f0f0f0", fontSize: 12, fontWeight: 700, color: "#666", letterSpacing: "0.8px", marginBottom: 20 }}>
          FAQ
        </div>
        <h2 style={{ fontSize: "clamp(2rem,3.5vw,3rem)", fontWeight: 900, letterSpacing: "-1.5px", color: "#1a1a1a", margin: 0 }}>
          Questions fréquentes
        </h2>
      </FadeIn>
      <div style={{ display: "grid", gap: 10 }}>
        {FAQS.map((faq, i) => (
          <FadeIn key={i} delay={i * 50}>
            <div style={{ background: "white", borderRadius: 12, border: "1px solid #e5e5e5", overflow: "hidden" }}>
              <button onClick={() => setOpen(open === i ? null : i)} style={{
                width: "100%", padding: "18px 22px", border: "none", background: "none",
                textAlign: "left", fontWeight: 600, fontSize: 15, color: "#1a1a1a", cursor: "pointer",
                display: "flex", justifyContent: "space-between", alignItems: "center", gap: 12,
              }}>
                {faq.q}
                <span style={{ fontSize: 22, color: "#ccc", transform: open === i ? "rotate(45deg)" : "none", transition: "0.2s", flexShrink: 0 }}>+</span>
              </button>
              {open === i && (
                <div style={{ padding: "0 22px 18px", fontSize: 14, color: "#777", lineHeight: 1.7 }}>{faq.a}</div>
              )}
            </div>
          </FadeIn>
        ))}
      </div>
    </section>
  );
}

function CTA() {
  return (
    <section style={{ background: "#1a1a1a", padding: "clamp(3.5rem,8vw,6rem) 40px clamp(5rem,10vw,8rem)", textAlign: "center" }}>
      <FadeIn>
        <h2 style={{ fontSize: "clamp(2rem,4vw,3.2rem)", fontWeight: 900, letterSpacing: "-1.5px", color: "white", margin: "0 0 20px" }}>
          Prêt à cloner votre boutique ?
        </h2>
        <p style={{ fontSize: 17, color: "#666", marginBottom: 44, maxWidth: "48ch", margin: "0 auto 44px" }}>
          Connectez vos clés API et lancez votre premier transfert en moins de 5 minutes.
        </p>
        <div style={{ display: "flex", gap: 14, justifyContent: "center", flexWrap: "wrap" }}>
          <Link href="/signup" style={{ padding: "15px 40px", borderRadius: 999, border: "none", background: "white", color: "#1a1a1a", fontWeight: 800, fontSize: 16, cursor: "pointer", textDecoration: "none", display: "inline-block" }}>
            Commencer gratuitement
          </Link>
          <a href="#features" style={{ padding: "15px 40px", borderRadius: 999, border: "2px solid #333", background: "transparent", color: "#666", fontWeight: 600, fontSize: 16, cursor: "pointer", textDecoration: "none", display: "inline-block" }}>
            Découvrir les fonctionnalités
          </a>
        </div>
        <p style={{ fontSize: 13, color: "#444", marginTop: 24 }}>Sans carte bancaire · Aperçu gratuit illimité</p>
      </FadeIn>
    </section>
  );
}

function Footer() {
  return (
    <footer style={{ background: "#111", padding: "28px 40px", display: "flex", alignItems: "center", justifyContent: "space-between", flexWrap: "wrap", gap: 16 }}>
      <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
        <img src={LOGO_DATA_URI} alt="ScaleYourShop" style={{ width: 28, height: 28, borderRadius: 6, objectFit: "cover" }} />
        <span style={{ fontWeight: 700, color: "#666", fontSize: 14 }}>Scale<span style={{ color: "#FA0C00" }}>Your</span>Shop</span>
      </div>
      <p style={{ fontSize: 12, color: "#444" }}>© 2026 ScaleYourShop · Tous droits réservés</p>
      <div style={{ display: "flex", gap: 20 }}>
        {[["Confidentialité", "/confidentialite"], ["CGU", "/cgu"]].map(([label, href]) => (
          <a key={label} href={href} style={{ fontSize: 12, color: "#444", textDecoration: "none" }}>{label}</a>
        ))}
      </div>
    </footer>
  );
}

// ── Page ──────────────────────────────────────────────────────────────────────
export default function HomePage() {
  const [scrolled, setScrolled] = useState(false);
  useEffect(() => {
    const fn = () => setScrolled(window.scrollY > 20);
    window.addEventListener("scroll", fn);
    return () => window.removeEventListener("scroll", fn);
  }, []);

  return (
    <div style={{ minHeight: "100dvh", background: "#fafafa" }}>
      <ResponsiveStyles />
      <Nav scrolled={scrolled} />
      <Hero />
      <SocialProof />
      <Features />
      <Pricing />
      <FAQ />
      <CTA />
      <Footer />
    </div>
  );
}
